Group {
  Anchor: (Width: 880, Height: 620);
  Background: PatchStyle(TexturePath: "../Textures/ResourceGame/panels/ui_panel_castle_ledger_base.png");
  Padding: (Full: 16);
  LayoutMode: Top;

  AssetImage #CastleInfoIcon { Anchor: (Width: 64, Height: 64, Bottom: 8); AssetPath: "../Textures/ResourceGame/icons/ui_icon_kingdom_castle.png"; }

  Label { Text: "Castle Info"; Style: (FontSize: 24, RenderBold: true); Anchor: (Bottom: 12); }

  Group {
    LayoutMode: Top;
    Anchor: (Bottom: 16);

    Label { Text: "Owner"; Style: (FontSize: 14, TextColor: #a7b0ba); }
    Label #OwnerName { Style: (FontSize: 16); Anchor: (Bottom: 10); }

    Label { Text: "Castle ID"; Style: (FontSize: 14, TextColor: #a7b0ba); }
    Label #CastleId { Style: (FontSize: 16); Anchor: (Bottom: 10); }

    Label { Text: "World"; Style: (FontSize: 14, TextColor: #a7b0ba); }
    Label #WorldName { Style: (FontSize: 16); Anchor: (Bottom: 10); }

    Label { Text: "Troops"; Style: (FontSize: 14, TextColor: #a7b0ba); }
    Label #TroopCount { Style: (FontSize: 16); Anchor: (Bottom: 10); }

    Label { Text: "Might"; Style: (FontSize: 14, TextColor: #a7b0ba); }
    Label #MightCount { Style: (FontSize: 16); }
  }

  Label #FeedbackStatus { Text: "Right-click the focused castle in-world to reopen this command surface."; Style: (FontSize: 14, TextColor: #e2c168); Anchor: (Bottom: 12); }

  Group {
    LayoutMode: Left;
    Anchor: (Bottom: 16);

    TextButton #AttackButton { Text: "Attack (Future)"; Background: PatchStyle(TexturePath: "../Textures/ResourceGame/buttons/ui_button_danger_normal.png"); Padding: (Full: 6); Anchor: (Right: 8); }
    TextButton #FriendButton { Text: "Add Friend (Future)"; Background: PatchStyle(TexturePath: "../Textures/ResourceGame/buttons/ui_button_secondary_normal.png"); Padding: (Full: 6); Anchor: (Right: 8); }
    TextButton #GuildButton { Text: "Guild Access (Future)"; Background: PatchStyle(TexturePath: "../Textures/ResourceGame/buttons/ui_button_secondary_normal.png"); Padding: (Full: 6); }
  }

  Label { Text: "Future: defenses, scouting, friend trust, guild permissions, banners, and dedicated castle assets."; Style: (FontSize: 14, TextColor: #a7b0ba); Anchor: (Bottom: 16); }

  Group { LayoutMode: Right; TextButton #BackButton { Text: "Back"; Background: PatchStyle(TexturePath: "../Textures/ResourceGame/buttons/ui_button_secondary_normal.png"); Padding: (Full: 6); } }
}
