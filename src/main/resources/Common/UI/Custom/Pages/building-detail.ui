Group {
  Anchor: (Width: 860, Height: 560);
  Background: PatchStyle(TexturePath: "../Textures/ResourceGame/panels/ui_panel_workshop_base.png");
  Padding: (Full: 16);
  LayoutMode: Top;

  AssetImage #BuildingIcon { Anchor: (Width: 64, Height: 64, Bottom: 8); AssetPath: "../Textures/ResourceGame/icons/ui_icon_action_upgrade.png"; }

  Label #BuildingTitle { Text: "Building"; Style: (FontSize: 24, RenderBold: true, RenderUppercase: true); Anchor: (Bottom: 6); }
  Label #AreaText { Style: (FontSize: 14, TextColor: #9eb0bf); Anchor: (Bottom: 4); }
  Label #LocationText { Style: (FontSize: 14, TextColor: #9eb0bf); Anchor: (Bottom: 16); }

  Group {
    LayoutMode: Left;
    Anchor: (Bottom: 16);

    Group {
      Anchor: (Width: 180);
      LayoutMode: Top;
      Label { Text: "Level"; Style: (FontSize: 14, TextColor: #9eb0bf); }
      Label #LevelText { Style: (FontSize: 22); }
    }

    Group {
      Anchor: (Width: 320);
      LayoutMode: Top;
      Label { Text: "Status"; Style: (FontSize: 14, TextColor: #9eb0bf); }
      Label #StatusText { Style: (FontSize: 18); }
    }
  }

  Label #EffectText { Style: (FontSize: 15, TextColor: #cfd8e1); Anchor: (Bottom: 12); }
  Label #NextUpgradeText { Style: (FontSize: 15, TextColor: #cfd8e1); Anchor: (Bottom: 16); }
  Label #FeedbackStatus { Style: (FontSize: 15, RenderBold: true); Anchor: (Bottom: 20); }

  Group {
    LayoutMode: Left;
    Anchor: (Bottom: 16);
    TextButton #StartUpgradeButton { Text: "Start Upgrade"; Background: PatchStyle(TexturePath: "../Textures/ResourceGame/buttons/ui_button_confirm_normal.png"); Padding: (Full: 6); Anchor: (Right: 8); }
    TextButton #CancelUpgradeButton { Text: "Cancel Upgrade"; Background: PatchStyle(TexturePath: "../Textures/ResourceGame/buttons/ui_button_danger_normal.png"); Padding: (Full: 6); Anchor: (Right: 8); }
    TextButton #OverviewButton { Text: "Building Overview"; Background: PatchStyle(TexturePath: "../Textures/ResourceGame/buttons/ui_button_secondary_normal.png"); Padding: (Full: 6); Anchor: (Right: 8); }
    TextButton #BackButton { Text: "Castle Menu"; Background: PatchStyle(TexturePath: "../Textures/ResourceGame/buttons/ui_button_secondary_normal.png"); Padding: (Full: 6); }
  }
}
