$C = "../Common.ui";

$C.@PageOverlay {}

$C.@Container {
  LayoutMode: Top;

  Group #Header {
    LayoutMode: Top;
    Anchor: (Bottom: 12);

    Label #Title {
      Text: "Your Castle";
      Style: (FontSize: 26, RenderBold: true, RenderUppercase: true);
      Anchor: (Bottom: 4);
    }

    Label #Subtitle {
      Text: "Citizen to army pipeline preview";
      Style: $C.@MutedTextStyle;
    }
  }

  Group #Stats {
    LayoutMode: Left;
    Anchor: (Bottom: 16, Height: 60);

    Group {
      Anchor: (Width: 180);
      LayoutMode: Top;
      Label { Text: "Citizens"; Style: $C.@SectionHeaderStyle; }
      Label #CitizenCount { Style: (FontSize: 20); }
    }

    Group {
      Anchor: (Width: 180);
      LayoutMode: Top;
      Label { Text: "Troops"; Style: $C.@SectionHeaderStyle; }
      Label #TroopCount { Style: (FontSize: 20); }
    }

    Group {
      Anchor: (Width: 260);
      LayoutMode: Top;
      Label { Text: "Resources"; Style: $C.@SectionHeaderStyle; }
      Label { Text: "Food:"; Style: $C.@MutedTextStyle; }
      Label #FoodCount { Style: (FontSize: 18); }
    }

    Group {
      Anchor: (Width: 120);
      LayoutMode: Top;
      Label { Text: "Wood:"; Style: $C.@MutedTextStyle; }
      Label #WoodCount { Style: (FontSize: 18); }
    }

    Group {
      Anchor: (Width: 120);
      LayoutMode: Top;
      Label { Text: "Iron:"; Style: $C.@MutedTextStyle; }
      Label #IronCount { Style: (FontSize: 18); }
    }
  }

  Group #Actions {
    LayoutMode: Left;
    Anchor: (Bottom: 16);

    TextButton #EnterInteriorButton { Text: "Enter Interior"; Padding: (Full: 6); Style: $C.@DefaultTextButtonStyle; Anchor: (Right: 8); }
    TextButton #CastleInfoButton { Text: "View Castle Info"; Padding: (Full: 6); Style: $C.@SecondaryTextButtonStyle; Anchor: (Right: 8); }
    TextButton #CitizensButton { Text: "Citizens"; Padding: (Full: 6); Style: $C.@SecondaryTextButtonStyle; Anchor: (Right: 8); }
    TextButton #TroopsButton { Text: "Troops"; Padding: (Full: 6); Style: $C.@SecondaryTextButtonStyle; Anchor: (Right: 8); }
    TextButton #ResourcesButton { Text: "Resources"; Padding: (Full: 6); Style: $C.@SecondaryTextButtonStyle; Anchor: (Right: 8); }
    TextButton #UpgradesButton { Text: "Upgrades"; Padding: (Full: 6); Style: $C.@DefaultTextButtonStyle; }
  }

  Group #Footer {
    LayoutMode: Right;
    TextButton #CloseButton { Text: "Close"; Padding: (Full: 6); Style: $C.@SecondaryTextButtonStyle; }
  }
}
