Group {
  Anchor: (Width: 880, Height: 620);
  Background: PatchStyle(TexturePath: "../Textures/ResourceGame/panels/ui_panel_castle_ledger_base.png");
  Padding: (Full: 16);
  LayoutMode: Top;

  AssetImage #MenuCrest { Anchor: (Width: 64, Height: 64, Bottom: 8); AssetPath: "../Textures/ResourceGame/icons/ui_icon_kingdom_castle.png"; }

  Group #Header {
    LayoutMode: Top;
    Anchor: (Bottom: 12);

    Label #Title {
      Text: "Your Castle";
      Style: (FontSize: 26, RenderBold: true, RenderUppercase: true);
      Anchor: (Bottom: 4);
    }

    Label #Subtitle {
      Text: "Citizen to army pipeline preview";
      Style: (FontSize: 14, TextColor: #a7b0ba);
    }
  }

  Group #Stats {
    LayoutMode: Left;
    Anchor: (Bottom: 16, Height: 60);

    Group {
      Anchor: (Width: 140);
      LayoutMode: Top;
      Label { Text: "Citizens"; Style: (FontSize: 18, RenderBold: true, RenderUppercase: true); }
      Label #CitizenCount { Style: (FontSize: 20); }
    }

    Group {
      Anchor: (Width: 140);
      LayoutMode: Top;
      Label { Text: "Troops"; Style: (FontSize: 18, RenderBold: true, RenderUppercase: true); }
      Label #TroopCount { Style: (FontSize: 20); }
    }

    Group {
      Anchor: (Width: 100);
      LayoutMode: Top;
      Label { Text: "Might"; Style: (FontSize: 18, RenderBold: true, RenderUppercase: true); }
      Label #MightCount { Style: (FontSize: 20); }
    }

    Group {
      Anchor: (Width: 180);
      LayoutMode: Top;
      Label { Text: "Resources"; Style: (FontSize: 18, RenderBold: true, RenderUppercase: true); }
      Label { Text: "Food:"; Style: (FontSize: 14, TextColor: #a7b0ba); }
      Label #FoodCount { Style: (FontSize: 18); }
    }

    Group {
      Anchor: (Width: 100);
      LayoutMode: Top;
      Label { Text: "Wood:"; Style: (FontSize: 14, TextColor: #a7b0ba); }
      Label #WoodCount { Style: (FontSize: 18); }
    }

    Group {
      Anchor: (Width: 100);
      LayoutMode: Top;
      Label { Text: "Iron:"; Style: (FontSize: 14, TextColor: #a7b0ba); }
      Label #IronCount { Style: (FontSize: 18); }
    }
  }

  Label {
    Text: "Outside the menu: the castle is a 3-block stone marker with owner, troop, and Might text. Right-click while focused to interact.";
    Style: (FontSize: 14, TextColor: #a7b0ba);
    Anchor: (Bottom: 16);
  }

  Group #Actions {
    LayoutMode: Left;
    Anchor: (Bottom: 16);

    TextButton #EnterInteriorButton { Text: "Enter Interior"; Background: PatchStyle(TexturePath: "../Textures/ResourceGame/buttons/ui_button_primary_normal.png"); Padding: (Full: 6); Anchor: (Right: 8); }
    TextButton #CastleInfoButton { Text: "View Castle Info"; Background: PatchStyle(TexturePath: "../Textures/ResourceGame/buttons/ui_button_secondary_normal.png"); Padding: (Full: 6); Anchor: (Right: 8); }
    TextButton #CitizensButton { Text: "Citizens"; Background: PatchStyle(TexturePath: "../Textures/ResourceGame/buttons/ui_button_secondary_normal.png"); Padding: (Full: 6); Anchor: (Right: 8); }
    TextButton #TroopsButton { Text: "Troops"; Background: PatchStyle(TexturePath: "../Textures/ResourceGame/buttons/ui_button_secondary_normal.png"); Padding: (Full: 6); Anchor: (Right: 8); }
    TextButton #ResourcesButton { Text: "Resources"; Background: PatchStyle(TexturePath: "../Textures/ResourceGame/buttons/ui_button_secondary_normal.png"); Padding: (Full: 6); Anchor: (Right: 8); }
    TextButton #UpgradesButton { Text: "Upgrades"; Background: PatchStyle(TexturePath: "../Textures/ResourceGame/buttons/ui_button_secondary_normal.png"); Padding: (Full: 6); }
    TextButton #BuildingsButton { Text: "Buildings"; Background: PatchStyle(TexturePath: "../Textures/ResourceGame/buttons/ui_button_secondary_normal.png"); Padding: (Full: 6); Anchor: (Left: 8); }
  }

  Group #WorldActions {
    LayoutMode: Left;
    Anchor: (Bottom: 16);

    TextButton #AttackButton { Text: "Attack Castle (Future)"; Background: PatchStyle(TexturePath: "../Textures/ResourceGame/buttons/ui_button_danger_normal.png"); Padding: (Full: 6); Anchor: (Right: 8); }
    TextButton #FriendButton { Text: "Add Friend (Future)"; Background: PatchStyle(TexturePath: "../Textures/ResourceGame/buttons/ui_button_secondary_normal.png"); Padding: (Full: 6); Anchor: (Right: 8); }
    TextButton #GuildButton { Text: "Guild Access (Future)"; Background: PatchStyle(TexturePath: "../Textures/ResourceGame/buttons/ui_button_secondary_normal.png"); Padding: (Full: 6); }
  }

  Group #Footer {
    LayoutMode: Right;
    TextButton #CloseButton { Text: "Close"; Background: PatchStyle(TexturePath: "../Textures/ResourceGame/buttons/ui_button_secondary_normal.png"); Padding: (Full: 6); }
  }
}
