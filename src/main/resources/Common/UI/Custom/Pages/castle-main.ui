Group {
  Anchor: (Width: 880, Height: 620);
  Background: (Color: #0e141c(0.88));
  Padding: (Full: 16);
  LayoutMode: Top;

  Group #Header {
    LayoutMode: Top;
    Anchor: (Bottom: 12);

    Label #Title {
      Text: "Your Castle";
      Style: (FontSize: 26, RenderBold: true, RenderUppercase: true);
      Anchor: (Bottom: 4);
    }

    Label #Subtitle {
      Text: "Citizen to army pipeline preview";
      Style: (FontSize: 14, TextColor: #a7b0ba);
    }
  }

  Group #Stats {
    LayoutMode: Left;
    Anchor: (Bottom: 16, Height: 60);

    Group {
      Anchor: (Width: 180);
      LayoutMode: Top;
      Label { Text: "Citizens"; Style: (FontSize: 18, RenderBold: true, RenderUppercase: true); }
      Label #CitizenCount { Style: (FontSize: 20); }
    }

    Group {
      Anchor: (Width: 180);
      LayoutMode: Top;
      Label { Text: "Troops"; Style: (FontSize: 18, RenderBold: true, RenderUppercase: true); }
      Label #TroopCount { Style: (FontSize: 20); }
    }

    Group {
      Anchor: (Width: 260);
      LayoutMode: Top;
      Label { Text: "Resources"; Style: (FontSize: 18, RenderBold: true, RenderUppercase: true); }
      Label { Text: "Food:"; Style: (FontSize: 14, TextColor: #a7b0ba); }
      Label #FoodCount { Style: (FontSize: 18); }
    }

    Group {
      Anchor: (Width: 120);
      LayoutMode: Top;
      Label { Text: "Wood:"; Style: (FontSize: 14, TextColor: #a7b0ba); }
      Label #WoodCount { Style: (FontSize: 18); }
    }

    Group {
      Anchor: (Width: 120);
      LayoutMode: Top;
      Label { Text: "Iron:"; Style: (FontSize: 14, TextColor: #a7b0ba); }
      Label #IronCount { Style: (FontSize: 18); }
    }
  }

  Label {
    Text: "Outside the menu: citizen yard, troop drill, and starter resource nodes are live placeholder visuals around the castle.";
    Style: (FontSize: 14, TextColor: #a7b0ba);
    Anchor: (Bottom: 16);
  }

  Group #Actions {
    LayoutMode: Left;
    Anchor: (Bottom: 16);

    TextButton #EnterInteriorButton { Text: "Enter Interior"; Padding: (Full: 6); Anchor: (Right: 8); }
    TextButton #CastleInfoButton { Text: "View Castle Info"; Padding: (Full: 6); Anchor: (Right: 8); }
    TextButton #CitizensButton { Text: "Citizens"; Padding: (Full: 6); Anchor: (Right: 8); }
    TextButton #TroopsButton { Text: "Troops"; Padding: (Full: 6); Anchor: (Right: 8); }
    TextButton #ResourcesButton { Text: "Resources"; Padding: (Full: 6); Anchor: (Right: 8); }
    TextButton #UpgradesButton { Text: "Upgrades"; Padding: (Full: 6); }
    TextButton #BuildingsButton { Text: "Buildings"; Padding: (Full: 6); Anchor: (Left: 8); }
  }

  Group #Footer {
    LayoutMode: Right;
    TextButton #CloseButton { Text: "Close"; Padding: (Full: 6); }
  }
}
