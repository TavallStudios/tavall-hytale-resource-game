Group {
  Anchor: (Width: 880, Height: 620);
  Background: (Color: #0e141c(0.88));
  Padding: (Full: 16);
  LayoutMode: Top;

  Label { Text: "Castle Interior"; Style: (FontSize: 24, RenderBold: true); Anchor: (Bottom: 12); }
  Label { Text: "Same-process private interior world with citizen and troop anchors."; Style: (FontSize: 14, TextColor: #a7b0ba); Anchor: (Bottom: 16); }
  Label #TutorialStatus { Style: (FontSize: 16, RenderBold: true); Anchor: (Bottom: 16); }

  Group {
    LayoutMode: Left;
    Anchor: (Bottom: 16);
    TextButton #ExitInteriorButton { Text: "Exit Interior"; Padding: (Full: 6); Anchor: (Right: 8); }
    TextButton #BuildingsButton { Text: "Buildings"; Padding: (Full: 6); Anchor: (Right: 8); }
    TextButton #BackButton { Text: "Castle Menu"; Padding: (Full: 6); }
  }

  Label { Text: "Future: build stations, upgrade rooms, worker routes, and richer interior decor."; Style: (FontSize: 14, TextColor: #a7b0ba); }
}
