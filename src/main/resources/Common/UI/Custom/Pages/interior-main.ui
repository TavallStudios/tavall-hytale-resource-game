Group {
  Anchor: (Width: 880, Height: 620);
  Background: PatchStyle(TexturePath: "../Textures/ResourceGame/panels/ui_panel_interior_base.png");
  Padding: (Full: 16);
  LayoutMode: Top;

  AssetImage #InteriorIcon { Anchor: (Width: 64, Height: 64, Bottom: 8); AssetPath: "../Textures/ResourceGame/icons/ui_icon_kingdom_castle.png"; }

  Label { Text: "Castle Interior"; Style: (FontSize: 24, RenderBold: true); Anchor: (Bottom: 12); }
  Label { Text: "Same-process private interior world with citizen and troop anchors."; Style: (FontSize: 14, TextColor: #a7b0ba); Anchor: (Bottom: 16); }
  Label #TutorialStatus { Style: (FontSize: 16, RenderBold: true); Anchor: (Bottom: 16); }

  Group {
    LayoutMode: Left;
    Anchor: (Bottom: 16);
    TextButton #ExitInteriorButton { Text: "Exit Interior"; Background: PatchStyle(TexturePath: "../Textures/ResourceGame/buttons/ui_button_primary_normal.png"); Padding: (Full: 6); Anchor: (Right: 8); }
    TextButton #BuildingsButton { Text: "Buildings"; Background: PatchStyle(TexturePath: "../Textures/ResourceGame/buttons/ui_button_secondary_normal.png"); Padding: (Full: 6); Anchor: (Right: 8); }
    TextButton #BackButton { Text: "Castle Menu"; Background: PatchStyle(TexturePath: "../Textures/ResourceGame/buttons/ui_button_secondary_normal.png"); Padding: (Full: 6); }
  }

  Label { Text: "Future: build stations, upgrade rooms, worker routes, and richer interior decor."; Style: (FontSize: 14, TextColor: #a7b0ba); }
}
