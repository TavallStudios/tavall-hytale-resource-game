Group {
  Anchor: (Width: 900, Height: 640);
  Background: PatchStyle(TexturePath: "../Textures/ResourceGame/panels/ui_panel_workshop_base.png");
  Padding: (Full: 16);
  LayoutMode: Top;

  AssetImage #BuildingsIcon { Anchor: (Width: 64, Height: 64, Bottom: 8); AssetPath: "../Textures/ResourceGame/icons/ui_icon_building_workshop.png"; }

  Label { Text: "Castle Buildings"; Style: (FontSize: 24, RenderBold: true, RenderUppercase: true); Anchor: (Bottom: 8); }
  Label { Text: "Surface buildings feed the economy. Interior buildings accelerate upgrades and military prep."; Style: (FontSize: 14, TextColor: #9eb0bf); Anchor: (Bottom: 16); }

  Label { Text: "Surface Yard"; Style: (FontSize: 18, RenderBold: true); Anchor: (Bottom: 8); }
  Label #FarmsteadStatus { Style: (FontSize: 14, TextColor: #cfd8e1); Anchor: (Bottom: 6); }
  Label #LumberMillStatus { Style: (FontSize: 14, TextColor: #cfd8e1); Anchor: (Bottom: 6); }
  Label #IronWorksStatus { Style: (FontSize: 14, TextColor: #cfd8e1); Anchor: (Bottom: 16); }

  Label { Text: "Interior Wing"; Style: (FontSize: 18, RenderBold: true); Anchor: (Bottom: 8); }
  Label #BarracksStatus { Style: (FontSize: 14, TextColor: #cfd8e1); Anchor: (Bottom: 6); }
  Label #WorkshopStatus { Style: (FontSize: 14, TextColor: #cfd8e1); Anchor: (Bottom: 16); }

  Label { Text: "Interaction: place with /kd buildings place <type>, then look at the finished or in-progress structure and interact with it to open the detail page."; Style: (FontSize: 14, TextColor: #9eb0bf); Anchor: (Bottom: 16); }
  Label #FooterStatus { Style: (FontSize: 15, RenderBold: true); Anchor: (Bottom: 16); }

  Label { Text: "Quick Stage"; Style: (FontSize: 18, RenderBold: true); Anchor: (Bottom: 8); }
  Group {
    LayoutMode: Left;
    Anchor: (Bottom: 10);

    TextButton #StageFarmsteadButton { Text: "Stage Farmstead"; Background: PatchStyle(TexturePath: "../Textures/ResourceGame/buttons/ui_button_primary_normal.png"); Padding: (Full: 6); Anchor: (Right: 8); }
    TextButton #StageLumberMillButton { Text: "Stage Lumber Mill"; Background: PatchStyle(TexturePath: "../Textures/ResourceGame/buttons/ui_button_primary_normal.png"); Padding: (Full: 6); Anchor: (Right: 8); }
    TextButton #StageIronWorksButton { Text: "Stage Iron Works"; Background: PatchStyle(TexturePath: "../Textures/ResourceGame/buttons/ui_button_primary_normal.png"); Padding: (Full: 6); Anchor: (Right: 8); }
    TextButton #StageBarracksButton { Text: "Stage Barracks"; Background: PatchStyle(TexturePath: "../Textures/ResourceGame/buttons/ui_button_primary_normal.png"); Padding: (Full: 6); Anchor: (Right: 8); }
    TextButton #StageWorkshopButton { Text: "Stage Workshop"; Background: PatchStyle(TexturePath: "../Textures/ResourceGame/buttons/ui_button_primary_normal.png"); Padding: (Full: 6); }
  }

  Group { LayoutMode: Right; TextButton #BackButton { Text: "Back"; Background: PatchStyle(TexturePath: "../Textures/ResourceGame/buttons/ui_button_secondary_normal.png"); Padding: (Full: 6); } }
}
