$C = "../Common.ui";

$C.@PageOverlay {}

$C.@Container {
  LayoutMode: Top;

  Label { Text: "Resources"; Style: (FontSize: 24, RenderBold: true); Anchor: (Bottom: 12); }

  Group {
    LayoutMode: Top;
    Anchor: (Bottom: 16);

    Label { Text: "Food"; Style: $C.@MutedTextStyle; }
    Label #FoodCount { Style: (FontSize: 22); Anchor: (Bottom: 8); }

    Label { Text: "Wood"; Style: $C.@MutedTextStyle; }
    Label #WoodCount { Style: (FontSize: 22); Anchor: (Bottom: 8); }

    Label { Text: "Iron"; Style: $C.@MutedTextStyle; }
    Label #IronCount { Style: (FontSize: 22); }
  }

  Label { Text: "Future: storage buildings and production chains."; Style: $C.@MutedTextStyle; Anchor: (Bottom: 16); }

  Group { LayoutMode: Right; TextButton #BackButton { Text: "Back"; Padding: (Full: 6); Style: $C.@DefaultTextButtonStyle; } }
}
